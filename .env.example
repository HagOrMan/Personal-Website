NEXT_PUBLIC_SITE_URL=<url of site>

# --- Private blog content (GitHub) -----------------------------------------
# Fine-grained PAT, read-only "Contents" permission, scoped to the private
# blog repo only. See BLOG_SETUP.md for how to create it.
BLOG_PAT_TOKEN=
BLOG_GITHUB_OWNER=
BLOG_GITHUB_REPO=

# --- Blog password protection ------------------------------------------------
# Unlocks every locked post, regardless of its own per-post password.
BLOG_MASTER_PASSWORD=
# 32+ random bytes used to sign the unlock cookie. Generate with:
#   openssl rand -base64 32
BLOG_SESSION_SECRET=
# Shared secret for the GitHub webhook that revalidates content on push.
# Generate with:
#   openssl rand -base64 32
BLOG_REVALIDATE_SECRET=

# --- Supabase (owner login, bypasses passwords) -----------------------------
# Safe to expose to the browser - these are the public project URL/anon key,
# not secrets. From Supabase dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Comma-separated Supabase auth user IDs (UUIDs) allowed to bypass passwords
# on every locked post. There is no roles table - this list is the sole
# authorization source for the owner bypass.
BLOG_OWNER_USER_IDS=

# --- Email Sending -----------------------------------------------------------
RESEND_API_KEY=
CONTACT_EMAIL_TO=
